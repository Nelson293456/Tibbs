rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // All-time leaderboard + player meta (bank, cats, items)
    match /scores/{uid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 16
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score < 10000
        && (!resource.exists ||
            request.resource.data.score >= resource.data.score);
    }

    // Daily leaderboards: /daily/{date}/scores/{uid}
    match /daily/{date}/scores/{uid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && date.matches('20[0-9][0-9]-[0-1][0-9]-[0-3][0-9]')
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 16
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score < 10000
        && (!resource.exists ||
            request.resource.data.score >= resource.data.score);
    }

    // Weekly leaderboards: /weekly/{week}/scores/{uid}
    match /weekly/{week}/scores/{uid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && week.matches('20[0-9][0-9]-W[0-5][0-9]')
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 16
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score < 10000
        && (!resource.exists ||
            request.resource.data.score >= resource.data.score);
    }
  }
}
